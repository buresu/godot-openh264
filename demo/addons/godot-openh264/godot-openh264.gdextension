[configuration]
entry_symbol = "godot_openh264_init"
compatibility_minimum = "4.3"
reloadable = false

[libraries]
windows.debug.x86_64   = "res://addons/godot-openh264/bin/libgodot-openh264.windows.debug.x86_64.dll"
windows.release.x86_64 = "res://addons/godot-openh264/bin/libgodot-openh264.windows.release.x86_64.dll"
windows.debug.arm64    = "res://addons/godot-openh264/bin/libgodot-openh264.windows.debug.arm64.dll"
windows.release.arm64  = "res://addons/godot-openh264/bin/libgodot-openh264.windows.release.arm64.dll"

macos.debug.arm64      = "res://addons/godot-openh264/bin/libgodot-openh264.macos.debug.arm64.dylib"
macos.release.arm64    = "res://addons/godot-openh264/bin/libgodot-openh264.macos.release.arm64.dylib"

linux.debug.x86_64     = "res://addons/godot-openh264/bin/libgodot-openh264.linux.debug.x86_64.so"
linux.release.x86_64   = "res://addons/godot-openh264/bin/libgodot-openh264.linux.release.x86_64.so"
linux.debug.arm64      = "res://addons/godot-openh264/bin/libgodot-openh264.linux.debug.arm64.so"
linux.release.arm64    = "res://addons/godot-openh264/bin/libgodot-openh264.linux.release.arm64.so"
